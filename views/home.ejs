<!DOCTYPE html>
<html lang="ko">
<head>
  <%- include('partials/head', {title: '홈'}) %>
  <style>
    .stories { display:flex; gap:12px; overflow-x:auto; padding:4px 0 12px; scrollbar-width:none; }
    .stories::-webkit-scrollbar { display:none; }
    .story { display:flex; flex-direction:column; align-items:center; gap:5px; cursor:pointer; flex-shrink:0; }
    .story-ring { width:62px; height:62px; border-radius:50%; padding:2.5px; background:linear-gradient(135deg,#f06292,#ffb347); }
    .story-img { width:100%; height:100%; border-radius:50%; object-fit:cover; border:2.5px solid #fff; }
    .story-ring.add-story { background:rgba(240,180,210,0.3); display:flex; align-items:center; justify-content:center; font-size:26px; }
    .story-name { font-size:11px; font-weight:700; color:#888; max-width:62px; text-align:center; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* post card */
    .post { background:var(--card-bg); border-radius:20px; border:1px solid rgba(255,255,255,0.7); box-shadow:var(--shadow); margin-bottom:14px; overflow:hidden; }
    .post-header { display:flex; align-items:center; gap:10px; padding:12px 14px 8px; }
    .post-img { width:100%; aspect-ratio:1/1; object-fit:cover; display:block; }
    .post-actions { display:flex; align-items:center; gap:14px; padding:10px 14px 4px; }
    .action-btn { background:none; border:none; font-size:22px; cursor:pointer; transition:transform .15s; padding:2px; }
    .action-btn:hover { transform:scale(1.15); }
    .action-dm { margin-left:auto; }
    .post-likes { padding:0 14px; font-size:13px; font-weight:700; color:#555; }
    .post-caption { padding:5px 14px 14px; font-size:13.5px; color:#555; line-height:1.5; }
    .post-caption strong { font-weight:800; color:#444; }
    .post-time { font-size:11px; color:#bbb; padding:0 14px 12px; }

    /* dm button top */
    .topbar-icons { display:flex; gap:14px; }
  </style>
</head>
<body>
  <div class="blob blob1"></div>
  <div class="blob blob2"></div>

  <div class="topbar">
    <span class="topbar-title">🍼 예쁜 아가</span>
    <div class="topbar-icons">
      <span class="topbar-icon">💌</span>
      <span class="topbar-icon">🔔</span>
    </div>
  </div>

  <div class="page">

    <!-- stories -->
    <div class="stories">
      <div class="story">
        <div class="story-ring add-story">➕</div>
        <span class="story-name">내 스토리</span>
      </div>
      <% const stories = [
        {name:'지우맘', seed:10},
        {name:'하율이', seed:20},
        {name:'서연맘', seed:30},
        {name:'민준아빠', seed:40},
        {name:'예은맘', seed:50},
        {name:'도윤이', seed:60},
      ]; %>
      <% stories.forEach(s => { %>
      <div class="story">
        <div class="story-ring">
          <img class="story-img" src="https://picsum.photos/seed/<%= s.seed %>/62/62" alt="<%= s.name %>" />
        </div>
        <span class="story-name"><%= s.name %></span>
      </div>
      <% }) %>
    </div>

    <!-- feed posts -->
    <% const posts = [
      {user:'지우맘 👶', avatar:10, img:101, likes:'좋아요 128개', caption:'오늘 지우 첫 이유식! 생각보다 잘 먹어서 감동 🥣💕', time:'3분 전', seed:101},
      {user:'하율이네 🌸', avatar:20, img:202, likes:'좋아요 94개', caption:'봄 나들이 나왔어요 🌷 하율이 첫 공원 나들이!!', time:'21분 전', seed:202},
      {user:'민준아빠 ⭐', avatar:40, img:303, likes:'좋아요 217개', caption:'민준이 100일 기념 사진 📸 벌써 100일이라니...', time:'1시간 전', seed:303},
    ]; %>
    <% posts.forEach(p => { %>
    <div class="post">
      <div class="post-header">
        <img class="avatar" src="https://picsum.photos/seed/<%= p.avatar %>/40/40" width="40" height="40" alt="avatar" />
        <div style="flex:1">
          <div style="font-weight:800;font-size:14px;color:#444"><%= p.user %></div>
          <div style="font-size:11px;color:#bbb"><%= p.time %></div>
        </div>
        <button style="background:none;border:none;font-size:20px;cursor:pointer;color:#bbb">•••</button>
      </div>
      <img class="post-img" src="https://picsum.photos/seed/<%= p.seed %>/480/480" alt="post" loading="lazy" />
      <div class="post-actions">
        <button class="action-btn">🤍</button>
        <button class="action-btn">💬</button>
        <button class="action-btn action-dm">📨</button>
      </div>
      <div class="post-likes"><%= p.likes %></div>
      <div class="post-caption"><strong><%= p.user.split(' ')[0] %></strong> <%= p.caption %></div>
    </div>
    <% }) %>

  </div>

  <%- include('partials/nav', {page:'home'}) %>
</body>
</html>
