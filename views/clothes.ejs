<!DOCTYPE html>
<html lang="ko">
<head>
  <%- include('partials/head', {title: '옷 합성'}) %>
  <style>
    .hero-badge {
      background: linear-gradient(135deg,rgba(255,240,248,0.9),rgba(255,252,235,0.9));
      border:1.5px solid rgba(255,255,255,0.75);
      border-radius:20px;
      padding:18px 20px;
      margin-bottom:20px;
      text-align:center;
      box-shadow: var(--shadow);
    }
    .hero-badge h2 { font-size:19px; font-weight:900; color:#555; margin-bottom:5px; }
    .hero-badge p { font-size:13px; color:#aaa; font-weight:600; line-height:1.5; }

    .upload-area {
      background:rgba(255,255,255,0.72);
      border:2px dashed rgba(240,98,146,0.3);
      border-radius:18px;
      padding:22px 16px;
      text-align:center;
      cursor:pointer;
      transition:border-color .2s, background .2s;
      margin-bottom:12px;
      position:relative;
    }
    .upload-area:hover { border-color:#f06292; background:rgba(255,255,255,0.9); }
    .upload-area.has-file { border-color:#f06292; border-style:solid; }
    .upload-area input[type=file] { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
    .upload-icon { font-size:38px; margin-bottom:8px; display:block; }
    .upload-label { font-size:14px; font-weight:700; color:#888; }
    .upload-sub { font-size:12px; color:#bbb; margin-top:3px; }
    .upload-preview {
      width:100%; max-height:180px;
      object-fit:cover;
      border-radius:12px;
      display:none;
      margin-bottom:6px;
    }
    .upload-preview.show { display:block; }
    .upload-filename { font-size:12px; color:#f06292; font-weight:700; margin-top:4px; }

    .result-box {
      background:linear-gradient(135deg,rgba(255,240,248,0.9),rgba(255,252,235,0.9));
      border:1.5px solid rgba(255,255,255,0.72);
      border-radius:20px;
      padding:24px;
      text-align:center;
      margin-top:8px;
      box-shadow:var(--shadow);
    }
    .result-placeholder { font-size:60px; display:block; margin-bottom:10px; animation:bounce 2.5s ease-in-out infinite; }
    @keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
    .result-placeholder-text { font-size:13px; color:#aaa; font-weight:600; }

    .result-img { width:100%; border-radius:14px; display:none; margin-bottom:12px; }
    .result-img.show { display:block; }

    .error-box { background:rgba(255,107,107,0.1); border:1.5px solid rgba(255,107,107,0.3); border-radius:14px; padding:12px 16px; color:#e05050; font-size:13px; font-weight:700; margin-top:10px; display:none; }
    .error-box.show { display:block; }

    .loading-overlay {
      display:none;
      flex-direction:column;
      align-items:center;
      gap:12px;
      padding:10px 0;
    }
    .loading-overlay.show { display:flex; }
    .spinner { width:44px; height:44px; border:4px solid rgba(240,98,146,0.2); border-top-color:#f06292; border-radius:50%; animation:spin 0.8s linear infinite; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .loading-text { font-size:14px; font-weight:700; color:#f06292; }

    .btn-synthesize {
      width:100%;
      padding:15px;
      background:linear-gradient(135deg,#f06292,#ffb347);
      color:#fff;
      font-size:16px;
      font-weight:800;
      font-family:'Nunito',sans-serif;
      border:none;
      border-radius:16px;
      cursor:pointer;
      box-shadow:0 6px 20px rgba(240,98,146,0.35);
      transition:transform .15s, box-shadow .15s;
      margin-top:4px;
    }
    .btn-synthesize:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 10px 28px rgba(240,98,146,0.45); }
    .btn-synthesize:disabled { opacity:0.6; cursor:not-allowed; transform:none; }

    .gcp-notice {
      background:rgba(255,243,224,0.9);
      border:1.5px solid rgba(255,167,38,0.3);
      border-radius:14px;
      padding:12px 14px;
      font-size:12.5px;
      color:#b07800;
      font-weight:700;
      margin-top:10px;
      text-align:center;
    }
  </style>
</head>
<body>
  <div class="blob blob1"></div>
  <div class="blob blob3"></div>

  <div class="topbar">
    <span class="topbar-title">👗 옷 합성</span>
  </div>

  <div class="page">

    <div class="hero-badge">
      <h2>✨ AI 옷 입혀보기</h2>
      <p>아기 사진과 옷을 업로드하면<br/>AI가 자동으로 합성해서 보여드려요!</p>
    </div>

    <form id="synthForm">
      <!-- step 1 -->
      <div class="section-title">① 아기 사진 업로드</div>
      <div class="upload-area" id="babyArea">
        <input type="file" id="babyFile" name="baby" accept="image/*" />
        <img class="upload-preview" id="babyPreview" src="" alt="아기 미리보기" />
        <span class="upload-icon" id="babyIcon">👶</span>
        <div class="upload-label" id="babyLabel">아기 사진을 올려주세요</div>
        <div class="upload-sub">JPG, PNG (최대 10MB) · 자동 리사이징 됩니다</div>
      </div>

      <!-- step 2 -->
      <div class="section-title">② 옷 사진 업로드</div>
      <div class="upload-area" id="clothArea">
        <input type="file" id="clothFile" name="cloth" accept="image/*" />
        <img class="upload-preview" id="clothPreview" src="" alt="옷 미리보기" />
        <span class="upload-icon" id="clothIcon">👕</span>
        <div class="upload-label" id="clothLabel">옷 사진을 올려주세요</div>
        <div class="upload-sub">배경 없는 흰 배경 옷 사진이 가장 잘 돼요</div>
      </div>

      <!-- step 3 -->
      <div class="section-title">③ 합성 결과</div>
      <div class="result-box" id="resultBox">
        <div class="loading-overlay" id="loadingArea">
          <div class="spinner"></div>
          <div class="loading-text">AI가 합성 중이에요... 잠시만요 🍼</div>
        </div>
        <div id="resultPlaceholder">
          <span class="result-placeholder">🍼</span>
          <div class="result-placeholder-text">아기 사진과 옷을 선택한 뒤<br/>합성하기 버튼을 눌러주세요</div>
        </div>
        <img class="result-img" id="resultImg" src="" alt="합성 결과" />

        <% if (!process.env.GCP_PROJECT_ID) { %>
        <div class="gcp-notice">⚠️ GCP Vertex AI 크리덴셜이 아직 설정되지 않았어요.<br/>설정 후 합성 기능이 활성화됩니다.</div>
        <% } %>
      </div>

      <div class="error-box" id="errorBox"></div>

      <button type="submit" class="btn-synthesize" id="synthBtn">✨ 합성하기</button>
    </form>

  </div>

  <%- include('partials/nav', {page:'clothes'}) %>

  <script>
    function setupUpload(inputId, previewId, iconId, labelId, areaId) {
      const input   = document.getElementById(inputId);
      const preview = document.getElementById(previewId);
      const icon    = document.getElementById(iconId);
      const label   = document.getElementById(labelId);
      const area    = document.getElementById(areaId);

      input.addEventListener('change', () => {
        const file = input.files[0];
        if (!file) return;
        const url = URL.createObjectURL(file);
        preview.src = url;
        preview.classList.add('show');
        icon.style.display = 'none';
        label.textContent = file.name;
        area.classList.add('has-file');
      });
    }

    setupUpload('babyFile',  'babyPreview',  'babyIcon',  'babyLabel',  'babyArea');
    setupUpload('clothFile', 'clothPreview', 'clothIcon', 'clothLabel', 'clothArea');

    document.getElementById('synthForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const babyFile  = document.getElementById('babyFile').files[0];
      const clothFile = document.getElementById('clothFile').files[0];
      const errorBox  = document.getElementById('errorBox');
      const loading   = document.getElementById('loadingArea');
      const placeholder = document.getElementById('resultPlaceholder');
      const resultImg = document.getElementById('resultImg');
      const synthBtn  = document.getElementById('synthBtn');

      errorBox.classList.remove('show');

      if (!babyFile || !clothFile) {
        errorBox.textContent = '⚠️ 아기 사진과 옷 사진을 모두 선택해 주세요.';
        errorBox.classList.add('show');
        return;
      }

      // 로딩 상태
      synthBtn.disabled = true;
      synthBtn.textContent = '합성 중...';
      loading.classList.add('show');
      placeholder.style.display = 'none';
      resultImg.classList.remove('show');

      try {
        const formData = new FormData();
        formData.append('baby',  babyFile);
        formData.append('cloth', clothFile);

        const res = await fetch('/api/clothes/synthesize', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();

        if (!res.ok || !data.success) throw new Error(data.error || '알 수 없는 오류');

        resultImg.src = data.resultUrl;
        resultImg.classList.add('show');
      } catch (err) {
        errorBox.textContent = `⚠️ ${err.message}`;
        errorBox.classList.add('show');
        placeholder.style.display = 'block';
      } finally {
        loading.classList.remove('show');
        synthBtn.disabled = false;
        synthBtn.textContent = '✨ 합성하기';
      }
    });
  </script>
</body>
</html>
