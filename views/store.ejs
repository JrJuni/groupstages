<!DOCTYPE html>
<html lang="ko">
<head>
  <%- include('partials/head', {title: '스토어'}) %>
  <style>
    .category-scroll {
      display:flex;
      gap:8px;
      overflow-x:auto;
      padding:4px 0 12px;
      scrollbar-width:none;
    }
    .category-scroll::-webkit-scrollbar { display:none; }
    .cat-chip {
      display:flex; flex-direction:column; align-items:center; gap:4px;
      padding:10px 14px;
      background:rgba(255,255,255,0.78);
      border:1.5px solid rgba(240,180,210,0.25);
      border-radius:16px;
      cursor:pointer;
      flex-shrink:0;
      transition:border-color .2s, background .2s;
      font-size:11px;
      font-weight:800;
      color:#888;
    }
    .cat-chip.active { background:linear-gradient(135deg,#f06292,#ffb347); color:#fff; border-color:transparent; box-shadow:0 4px 14px rgba(240,98,146,0.28); }
    .cat-chip:hover:not(.active) { border-color:#f06292; }
    .cat-chip .cat-icon { font-size:22px; }

    .store-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .product-card {
      background:var(--card-bg);
      border-radius:18px;
      border:1px solid rgba(255,255,255,0.72);
      box-shadow:var(--shadow);
      overflow:hidden;
      cursor:pointer;
      transition:transform .15s;
    }
    .product-card:hover { transform:translateY(-2px); }
    .product-thumb {
      width:100%; aspect-ratio:1/1;
      object-fit:cover;
      display:block;
    }
    .product-thumb-emoji {
      width:100%; aspect-ratio:1/1;
      display:flex; align-items:center; justify-content:center;
      font-size:52px;
      background:linear-gradient(135deg,rgba(255,240,248,0.85),rgba(255,252,235,0.85));
    }
    .product-info { padding:10px 12px 12px; }
    .product-brand { font-size:10px; font-weight:800; color:#f06292; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:3px; }
    .product-name { font-size:13px; font-weight:700; color:#555; line-height:1.3; margin-bottom:6px; }
    .product-price { font-size:16px; font-weight:900; color:#444; }
    .product-original { font-size:12px; color:#ccc; text-decoration:line-through; margin-left:5px; font-weight:600; }
    .product-badge { display:inline-block; background:#ffe3ef; color:#f06292; font-size:10px; font-weight:800; padding:2px 7px; border-radius:99px; margin-bottom:5px; }

    .banner {
      background:linear-gradient(135deg,#f06292,#ffb347);
      border-radius:20px;
      padding:18px 20px;
      color:#fff;
      margin-bottom:16px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      box-shadow:0 6px 20px rgba(240,98,146,0.32);
    }
    .banner h3 { font-size:17px; font-weight:900; margin-bottom:4px; }
    .banner p { font-size:12px; opacity:.85; }
    .banner-emoji { font-size:48px; }
  </style>
</head>
<body>
  <div class="blob blob1"></div>
  <div class="blob blob2"></div>

  <div class="topbar">
    <span class="topbar-title">🏪 스토어</span>
    <span class="topbar-icon">🔍</span>
  </div>

  <div class="page">

    <div class="search-bar">
      <span>🔍</span>
      <input type="text" placeholder="브랜드, 제품 검색" />
    </div>

    <!-- banner -->
    <div class="banner">
      <div>
        <h3>🎉 신규 가맹점 특가!</h3>
        <p>이번 주 입점 브랜드 최대 30% 할인</p>
      </div>
      <span class="banner-emoji">🛍️</span>
    </div>

    <!-- categories -->
    <div class="category-scroll">
      <% const cats = [
        {icon:'🌟', label:'전체', active:true},
        {icon:'👶', label:'의류'},
        {icon:'🍼', label:'수유용품'},
        {icon:'🛁', label:'목욕용품'},
        {icon:'🪑', label:'유아가구'},
        {icon:'🎠', label:'장난감'},
        {icon:'📚', label:'도서'},
      ]; %>
      <% cats.forEach(c => { %>
      <div class="cat-chip <%= c.active?'active':'' %>">
        <span class="cat-icon"><%= c.icon %></span>
        <%= c.label %>
      </div>
      <% }) %>
    </div>

    <div class="section-title" style="margin-top:0">인기 상품</div>
    <div class="store-grid">
      <% const products = [
        {brand:'베베누보', name:'신생아 배냇저고리 세트', price:'24,900', original:'32,000', badge:'인기', emoji:'👕'},
        {brand:'마미쿨', name:'순면 아기 수건 5매입', price:'15,000', original:'', badge:'신상', emoji:'🧸'},
        {brand:'리틀락', name:'젖병 소독기 UV-C', price:'89,000', original:'110,000', badge:'SALE', emoji:'🍼'},
        {brand:'도담', name:'유기농 아기 로션 200ml', price:'18,500', original:'', badge:'', emoji:'🧴'},
        {brand:'픽미베이비', name:'접이식 아기 욕조', price:'34,000', original:'42,000', badge:'SALE', emoji:'🛁'},
        {brand:'스위트베이비', name:'딸랑이 & 치발기 세트', price:'12,000', original:'', badge:'인기', emoji:'🎀'},
      ]; %>
      <% products.forEach(p => { %>
      <div class="product-card">
        <div class="product-thumb-emoji"><%= p.emoji %></div>
        <div class="product-info">
          <% if(p.badge) { %><div class="product-badge"><%= p.badge %></div><% } %>
          <div class="product-brand"><%= p.brand %></div>
          <div class="product-name"><%= p.name %></div>
          <div>
            <span class="product-price"><%=p.price%>원</span>
            <% if(p.original) { %><span class="product-original"><%=p.original%>원</span><% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

  </div>

  <%- include('partials/nav', {page:'store'}) %>
</body>
</html>
