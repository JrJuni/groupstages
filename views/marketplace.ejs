<!DOCTYPE html>
<html lang="ko">
<head>
  <%- include('partials/head', {title: '중고 장터'}) %>
  <style>
    .filter-tabs {
      display:flex;
      gap:8px;
      margin-bottom:14px;
    }
    .filter-tab {
      flex:1;
      padding:10px;
      border-radius:12px;
      font-family:'Nunito',sans-serif;
      font-size:14px;
      font-weight:800;
      cursor:pointer;
      border:2px solid transparent;
      transition:all .2s;
      text-align:center;
    }
    .filter-tab.all { background:linear-gradient(135deg,#f06292,#ffb347); color:#fff; box-shadow:0 4px 14px rgba(240,98,146,0.3); }
    .filter-tab.buy { background:rgba(227,240,255,0.8); color:#4a90e2; border-color:rgba(74,144,226,0.2); }
    .filter-tab.sell { background:rgba(255,227,239,0.8); color:#f06292; border-color:rgba(240,98,146,0.2); }

    .market-item {
      background:var(--card-bg);
      border-radius:18px;
      border:1px solid rgba(255,255,255,0.72);
      box-shadow:var(--shadow);
      display:flex;
      gap:12px;
      padding:12px;
      margin-bottom:12px;
      cursor:pointer;
      transition:transform .15s;
    }
    .market-item:hover { transform:translateY(-1px); }
    .market-thumb {
      width:80px; height:80px;
      border-radius:12px;
      object-fit:cover;
      flex-shrink:0;
    }
    .market-info { flex:1; min-width:0; }
    .market-title { font-size:14px; font-weight:800; color:#444; margin-bottom:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .market-desc { font-size:12px; color:#aaa; margin-bottom:8px; }
    .market-price { font-size:16px; font-weight:900; color:#f06292; }
    .market-meta { display:flex; align-items:center; gap:8px; margin-top:5px; }
    .market-loc { font-size:11px; color:#bbb; }

    .fab {
      position:fixed;
      bottom:calc(var(--nav-h) + 16px);
      right:20px;
      width:54px; height:54px;
      background:linear-gradient(135deg,#f06292,#ffb347);
      border-radius:50%;
      display:flex; align-items:center; justify-content:center;
      font-size:26px;
      box-shadow:0 6px 20px rgba(240,98,146,0.4);
      cursor:pointer;
      z-index:50;
      border:none;
      transition:transform .15s;
    }
    .fab:hover { transform:scale(1.08); }
  </style>
</head>
<body>
  <div class="blob blob1"></div>
  <div class="blob blob2"></div>

  <div class="topbar">
    <span class="topbar-title">🛒 중고 장터</span>
    <span class="topbar-icon">🔍</span>
  </div>

  <div class="page">

    <div class="search-bar">
      <span>🔍</span>
      <input type="text" placeholder="아기 용품 검색" />
    </div>

    <div class="filter-tabs">
      <div class="filter-tab all">전체</div>
      <div class="filter-tab buy">구매</div>
      <div class="filter-tab sell">판매</div>
    </div>

    <% const items = [
      {tag:'sell', emoji:'👕', title:'유아 내복 세트 (6~12개월)', desc:'두 번 입힌 새것 같아요', price:'8,000원', loc:'서울 마포구', seed:11},
      {tag:'buy', emoji:'🚼', title:'바운서 구합니다 (핀바운서)', desc:'상태 좋으면 구매할게요!', price:'50,000원 이하', loc:'경기 성남시', seed:22},
      {tag:'sell', emoji:'🍼', title:'젖병 소독기 (리틀락)', desc:'6개월 사용, 깨끗합니다', price:'25,000원', loc:'인천 연수구', seed:33},
      {tag:'sell', emoji:'🛁', title:'아기 욕조 (리치기)', desc:'접이식, 보관 편해요', price:'12,000원', loc:'서울 강남구', seed:44},
      {tag:'buy', emoji:'🪑', title:'하이체어 삽니다', desc:'이케아 안틸로프도 좋아요', price:'30,000원 이하', loc:'서울 송파구', seed:55},
    ]; %>

    <% items.forEach(it => { %>
    <div class="market-item">
      <div style="width:80px;height:80px;border-radius:12px;background:linear-gradient(135deg,rgba(255,240,248,0.9),rgba(255,252,235,0.9));display:flex;align-items:center;justify-content:center;font-size:36px;flex-shrink:0;">
        <%= it.emoji %>
      </div>
      <div class="market-info">
        <div style="margin-bottom:5px;">
          <span class="tag tag-<%= it.tag %>"><%= it.tag==='buy'?'구매':'판매' %></span>
        </div>
        <div class="market-title"><%= it.title %></div>
        <div class="market-desc"><%= it.desc %></div>
        <div class="market-price"><%= it.price %></div>
        <div class="market-meta">
          <span class="market-loc">📍 <%= it.loc %></span>
        </div>
      </div>
    </div>
    <% }) %>

  </div>

  <button class="fab">✏️</button>
  <%- include('partials/nav', {page:'marketplace'}) %>
</body>
</html>
